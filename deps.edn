{;; File system paths
 :paths ["src" "resources"]

 ;; Dependencies
 :deps {;; Core
        org.clojure/clojure {:mvn/version "1.12.4"} ; language
        org.clojure/core.async {:mvn/version "1.8.741"} ; async
        }

 ;; Clojure CLI aliases (clj)
 :aliases
 {;;; Development ;;;

  ;; Development REPL with nREPL for Calva/VSCode
  :dev {:extra-paths ["dev"]
        :extra-deps {nrepl/nrepl {:mvn/version "1.6.0"}
                     cider/cider-nrepl {:mvn/version "0.58.0"}
                     criterium/criterium {:mvn/version "0.4.6"}}}

  ;;; Quality ;;;

  ;; Lint code: clj -M:lint src/ test/
  :lint {:extra-deps {clj-kondo/clj-kondo {:mvn/version "2026.01.19"}}
         :main-opts ["-m" "clj-kondo.main" "--lint"]}

  ;; Format code: clj -M:cljfmt fix src/ test/
  ;; Check format: clj -M:cljfmt check src/ test/
  :cljfmt {:extra-deps {dev.weavejester/cljfmt {:mvn/version "0.16.1"}}
           :main-opts ["-m" "cljfmt.main"]}

  ;; Run tests: clj -X:test OR clj -M:test
  ;; Excludes integration tests by default.
  :test {:extra-paths ["test"]
         :extra-deps {org.clojure/test.check {:mvn/version "1.1.3"}
                      io.github.cognitect-labs/test-runner {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         ;; For clj -X:test
         :exec-fn cognitect.test-runner.api/test
         :exec-args {:excludes [:integration :strict]}
         ;; For clj -M:test (calls System/exit — preferred)
         :main-opts ["-m" "cognitect.test-runner" "-e" ":integration" "-e" ":strict"]}

  ;; Run tests matching pattern: clj -X:test-m :p <pattern>
  ;; Example: clj -X:test-m :p core
  :test-m {:extra-paths ["test" "dev"]
           :extra-deps {org.clojure/test.check {:mvn/version "1.1.3"}
                        io.github.cognitect-labs/test-runner {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
           :exec-fn test-runner/match}

  ;; Run integration tests: clj -X:test-integration
  :test-integration {:extra-paths ["test"]
                     :extra-deps {org.clojure/test.check {:mvn/version "1.1.3"}
                                  io.github.cognitect-labs/test-runner {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
                     ;; For clj -X:test-integration
                     :exec-fn cognitect.test-runner.api/test
                     :exec-args {:includes [:integration]}
                     ;; For clj -M:test-integration (calls System/exit — preferred)
                     :main-opts ["-m" "cognitect.test-runner" "-i" ":integration"]}

  ;; Run integration tests matching pattern: clj -X:test-integration-m :p <pattern>
  :test-integration-m {:extra-paths ["test" "dev"]
                       :extra-deps {org.clojure/test.check {:mvn/version "1.1.3"}
                                    io.github.cognitect-labs/test-runner {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
                       :exec-fn test-runner/match-integration}

  ;;; Build ;;;

  ;; Build tasks: clj -T:build <task>, eg: clj -T:build jar (see build.clj for tasks)
  :build {:deps {io.github.clojure/tools.build {:mvn/version "0.10.12"}
                 slipset/deps-deploy {:mvn/version "0.2.2"}}
          :ns-default build}

  ;;; Maintenance ;;;

  ;; Check for outdated deps: clj -M:outdated
  ;; Upgrade outdated deps: clj -M:outdated --upgrade
  :outdated {:deps {com.github.liquidz/antq {:mvn/version "RELEASE"}}
             :main-opts ["-m" "antq.core"]}}}
